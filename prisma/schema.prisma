generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VaultRole {
  owner
  editor
  member
}

enum PlantSpeciesSource {
  seed
  perenual
  ai
}

model User {
  id               String               @id @default(uuid()) @db.Uuid
  email            String               @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  accounts         Account[]
  sessions         Session[]
  memberships      VaultMember[]
  createdInvites   VaultInvite[]        @relation("VaultInviteCreator")
  acceptedInvites  VaultInvite[]        @relation("VaultInviteAcceptor")
  reminderEmails   ReminderEmail[]
  wateringEvents   PlantWateringEvent[]
  notificationSettings NotificationSetting[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Vault {
  id          String           @id @default(uuid()) @db.Uuid
  name        String
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  memberships VaultMember[]
  plants      Plant[]
  invites     VaultInvite[]
  notificationSettings NotificationSetting[]

  @@map("vaults")
}

model VaultMember {
  vaultId   String    @map("vault_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      VaultRole @default(member)
  createdAt DateTime  @default(now()) @map("created_at")
  vault     Vault     @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([vaultId, userId])
  @@map("vault_members")
}

model PlantSpecies {
  id                     String              @id @default(uuid()) @db.Uuid
  scientificName         String              @unique @map("scientific_name")
  normalizedLookupKey    String              @unique @map("normalized_lookup_key")
  wateringIntervalDays   Int                 @map("watering_interval_days")
  fertilizerIntervalDays Int?                @map("fertilizer_interval_days")
  lightRequirement       String?             @map("light_requirement")
  soilType               String?             @map("soil_type")
  petToxic               Boolean?            @map("pet_toxic")
  careNotes              String?             @map("care_notes")
  source                 PlantSpeciesSource
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  aliases                PlantSpeciesAlias[]
  plants                 Plant[]

  @@map("plant_species")
}

model PlantSpeciesAlias {
  id                 String       @id @default(uuid()) @db.Uuid
  speciesId          String       @map("species_id") @db.Uuid
  aliasName          String       @map("alias_name")
  normalizedAliasKey String       @unique @map("normalized_alias_key")
  createdAt          DateTime     @default(now()) @map("created_at")
  species            PlantSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([speciesId, normalizedAliasKey])
  @@map("plant_species_aliases")
}

model Plant {
  id                        String               @id @default(uuid()) @db.Uuid
  vaultId                   String               @map("vault_id") @db.Uuid
  speciesId                 String               @map("species_id") @db.Uuid
  nickname                  String
  imageUrl                  String?              @map("image_url")
  customWateringIntervalDays Int?                @map("custom_watering_interval_days")
  lastWateredAt             DateTime?            @map("last_watered_at")
  nextWateringAt            DateTime             @map("next_watering_at")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  vault                     Vault                @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  species                   PlantSpecies         @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  wateringEvents       PlantWateringEvent[]
  notificationSettings NotificationSetting[]

  @@index([vaultId, nextWateringAt])
  @@map("plants")
}

model NotificationSetting {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  vaultId      String?  @map("vault_id") @db.Uuid
  plantId      String?  @map("plant_id") @db.Uuid
  emailEnabled Boolean  @default(false) @map("email_enabled")
  pushEnabled  Boolean  @default(false) @map("push_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault        Vault?   @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  plant        Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([userId, vaultId])
  @@unique([userId, plantId])
  @@map("notification_settings")
}

model PlantWateringEvent {
  id         String   @id @default(uuid()) @db.Uuid
  plantId    String   @map("plant_id") @db.Uuid
  wateredBy  String   @map("watered_by") @db.Uuid
  wateredAt  DateTime @default(now()) @map("watered_at")
  createdAt  DateTime @default(now()) @map("created_at")
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [wateredBy], references: [id], onDelete: Cascade)

  @@index([plantId, wateredAt])
  @@map("plant_watering_events")
}

model VaultInvite {
  id           String    @id @default(uuid()) @db.Uuid
  vaultId       String    @map("vault_id") @db.Uuid
  token         String    @unique
  code          String?   @unique
  email         String?
  createdById   String    @map("created_by_id") @db.Uuid
  acceptedById  String?   @map("accepted_by_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at")
  acceptedAt    DateTime? @map("accepted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  vault         Vault     @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  createdBy     User      @relation("VaultInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedBy    User?     @relation("VaultInviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([vaultId, expiresAt])
  @@map("vault_invites")
}

model ReminderEmail {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  reminderDate DateTime @map("reminder_date")
  plantIds     String[] @map("plant_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reminderDate])
  @@map("reminder_emails")
}
