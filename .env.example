DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plant_keeper?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
PLANT_ID_API_KEY="your-plant-id-api-key"
AI_API_KEY="your-openai-compatible-api-key"
AI_API_URL="https://api.openai.com/v1/chat/completions"
AI_MODEL="gpt-4.1-mini"
RESEND_API_KEY="your-resend-api-key"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASSWORD="smtp-password"
SMTP_SECURE="false"
EMAIL_FROM="Plant Keeper <noreply@example.com>"
APP_URL="http://localhost:3000"
CRON_SECRET="replace-with-an-internal-secret"
REMINDER_HOUR="8"
PLANT_KEEPER_DEV_MODE="false"
# Comma-separated emails with access to /admin
ADMIN_EMAILS="you@example.com"
# Vercel Blob storage token — required on Vercel (no persistent filesystem);
# local dev falls back to public/uploads when unset
BLOB_READ_WRITE_TOKEN=""
# Global daily cap for AI photo identifications (cost circuit breaker, default 30)
IDENTIFY_GLOBAL_DAILY_LIMIT="30"
